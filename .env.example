# LLM — free at https://console.groq.com
GROQ_API_KEY=

# Vector DB — free 1 GB cluster at https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Inngest Cloud — free at https://app.inngest.com  (leave blank for local dev)
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# Inngest REST API base used by Streamlit to poll run status
#   Local dev  : http://127.0.0.1:8288/v1   (default, no need to set)
#   Inngest Cloud: https://api.inngest.com/v1
INNGEST_API_BASE=
